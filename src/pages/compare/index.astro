---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Sammenlign IPTV Tjenester - IPTV Norway" description="Hvorfor velge IPTV Norway? Sammenlign vårt iptv abonnement med tradisjonelle TV-løsninger og oppdag hvor mye du kan spare.">
  <div class="pt-32 pb-20 px-4 max-w-4xl mx-auto min-h-[70vh]">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">IPTV Norway vs <span class="text-[var(--color-brand-red)]">Alternativene</span></h1>
      <p class="text-xl text-gray-400">Se hvorfor vi leverer Norges beste IPTV abonnement.</p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-6">
      <a href="/compare/iptv-vs-parabol" class="glass p-8 rounded-2xl hover:border-[var(--color-brand-red)] transition-colors group block">
        <h2 class="text-2xl font-bold mb-3 group-hover:text-[var(--color-brand-red)] transition-colors">IPTV vs Tradisjonell TV / Parabol</h2>
        <p class="text-gray-400">Lær hvorfor tusenvis av nordmenn bytter fra dyre kabel-TV og parabol-pakker til et rimeligere og mer fleksibelt iptv abonnement.</p>
      </a>
    </div>
  </div>
</Layout>
