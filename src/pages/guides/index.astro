---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="IPTV Guider og Hjelp - IPTV Norway" description="Lær hvordan du setter opp IPTV Norway på ulike enheter. Omfattende guider for beste iptv opplevelse.">
  <div class="pt-32 pb-20 px-4 max-w-4xl mx-auto min-h-[70vh]">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">IPTV <span class="text-[var(--color-brand-red)]">Guider</span></h1>
      <p class="text-xl text-gray-400">Alt du trenger for å komme i gang med Norges beste IPTV abonnement.</p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-6">
      <a href="/guides/oppsett-av-iptv" class="glass p-8 rounded-2xl hover:border-[var(--color-brand-red)] transition-colors group block">
        <h2 class="text-2xl font-bold mb-3 group-hover:text-[var(--color-brand-red)] transition-colors">Slik setter du opp IPTV</h2>
        <p class="text-gray-400">En komplett, trinn-for-trinn guide til hvordan du installerer og bruker vårt IPTV abonnement på din Smart TV, strømmeboks, eller mobil.</p>
      </a>
      <!-- Placeholder for more guides -->
      <div class="glass p-8 rounded-2xl border-white/5 opacity-50 cursor-not-allowed">
        <h2 class="text-2xl font-bold mb-3">Feilsøking og Tips</h2>
        <p class="text-gray-400">Kommer snart. Lær hvordan du optimaliserer din tilkobling for en strømmefri opplevelse i 4K.</p>
      </div>
    </div>
  </div>
</Layout>
