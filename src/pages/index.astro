---
import Layout from '../layouts/Layout.astro';
import { Play } from 'lucide-astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import SupportedDevices from '../components/SupportedDevices.astro';
import PricingCard from '../components/PricingCard.astro';
import UserReviewsSection from '../components/UserReviewsSection.astro';
import SetupSteps from '../components/SetupSteps.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ReferralBanner from '../components/ReferralBanner.astro';
import LiveScores from '../components/widgets/LiveScores.astro';
---

<Layout title="IPTV Norway - Norges Beste IPTV Abonnement" description="Velg IPTV Norway for en krystallklar 4K opplevelse. Skaff deg et stabilt iptv abonnement og nyt den beste iptv tjenesten med et enormt utvalg av kanaler.">
  <div class="relative min-h-[80vh] flex items-center justify-center pt-32 pb-16 px-4">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-brand-blue)]/90 to-[var(--color-dark-bg)] z-10"></div>
      <img src="/images/hero.png" alt="beste iptv abonnement i norge for stuen din" class="w-full h-full object-cover opacity-70 mix-blend-overlay absolute inset-0" />
    </div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
        Opplev Premium <span class="text-[var(--color-brand-red)]">IPTV Norway</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 mb-10 max-w-2xl mx-auto">
        Krystallklar 4K-kvalitet, ingen frysing, og det største utvalget av norske og internasjonale kanaler.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#priser" class="px-8 py-4 bg-[var(--color-brand-red)] hover:bg-red-700 text-white rounded-full font-bold text-lg transition-all transform hover:scale-105 flex items-center gap-2 w-full sm:w-auto justify-center">
          <Play class="w-5 h-5" />
          Se Våre Pakker
        </a>
        <a href="/contact" class="px-8 py-4 glass hover:bg-white/10 text-white rounded-full font-bold text-lg transition-all w-full sm:w-auto justify-center">
          Kontakt Oss
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4">
    <FeatureGrid />
    <WhyChooseUs />
    <PricingCard />
    <ReferralBanner />
    <SupportedDevices />
    
    <div class="my-20 rounded-3xl overflow-hidden border border-white/10 shadow-[0_0_50px_rgba(186,12,47,0.2)]">
      <img src="/images/interface.png" alt="iptv norway kanaloversikt og krystallklar 4k kvalitet" class="w-full h-auto object-cover" />
    </div>

    <SetupSteps />
    <UserReviewsSection />
  </div>

  <LiveScores />

  <!-- SEO CTA Section -->
  <section class="py-24 px-4 bg-gradient-to-b from-transparent to-black/50 border-t border-[var(--color-glass-border)] relative overflow-hidden">
    <!-- Background effects -->
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl h-64 bg-[var(--color-brand-red)]/20 blur-[100px] rounded-full pointer-events-none"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center glass p-10 md:p-16 rounded-3xl border border-white/10 shadow-2xl">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white">
        Hvorfor er IPTV Norway det <span class="text-[var(--color-brand-red)]">beste IPTV abonnementet</span> i Norge?
      </h2>
      
      <p class="text-lg md:text-xl text-gray-300 mb-10 leading-relaxed max-w-3xl mx-auto">
        Krystallklar 4K-kvalitet, sylskarpe sportssendinger uten buffering, og Norges største kanalutvalg. 
        Skaff deg Norges <strong>beste iptv</strong> i dag og opplev en ny æra av underholdning med vårt premium <strong>iptv abonnement</strong>.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#priser" class="w-full sm:w-auto px-10 py-5 bg-[var(--color-brand-red)] hover:bg-red-700 text-white rounded-full font-bold text-lg transition-all transform hover:scale-105 shadow-[0_0_20px_rgba(186,12,47,0.5)]">
          Se Våre Pakker Nå
        </a>
        <a href="https://wa.me/18036582620" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-10 py-5 glass hover:bg-white/10 text-white rounded-full font-bold text-lg transition-colors flex items-center justify-center gap-2">
          Kontakt Oss på WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
