---
import Layout from '../../layouts/Layout.astro';
import PricingCard from '../../components/PricingCard.astro';
import SetupSteps from '../../components/SetupSteps.astro';
---

<Layout title="IPTV Abonnement Bergen - Beste IPTV i Bergen | IPTV Norway" description="Få det beste iptv abonnementet i Bergen. Krystallklar 4K strømming, all sport og film direkte hjem til deg i Bergen med IPTV Norway.">
  <div class="pt-32 pb-10 px-4 max-w-4xl mx-auto text-center">
    <h1 class="text-5xl md:text-6xl font-bold mb-6">Det Beste <span class="text-[var(--color-brand-red)]">IPTV Abonnement i Bergen</span></h1>
    <p class="text-xl text-gray-300 mb-10">
      Nyt stabilt og premium IPTV i Bergen med IPTV Norway.
    </p>
  </div>

  <section class="py-12 px-4 max-w-4xl mx-auto prose prose-invert prose-red text-center">
    <p class="text-lg">
      Er du i <strong>Bergen</strong> og vil ha den <strong>beste iptv</strong>-opplevelsen? Vårt premium <strong>iptv abonnement</strong> gir deg tilgang til endeløs underholdning i topp kvalitet, perfekt optimalisert for ditt nettverk i Bergen og omegn.
    </p>
  </section>

  <SetupSteps />
  <PricingCard />
</Layout>
