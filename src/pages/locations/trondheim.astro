---
import Layout from '../../layouts/Layout.astro';
import PricingCard from '../../components/PricingCard.astro';
import SetupSteps from '../../components/SetupSteps.astro';
---

<Layout title="IPTV Abonnement Trondheim - Beste IPTV i Trondheim | IPTV Norway" description="Kjøp det beste iptv abonnementet i Trondheim. Vi i IPTV Norway leverer overlegen kvalitet og stabilitet for deg i Trondheim.">
  <div class="pt-32 pb-10 px-4 max-w-4xl mx-auto text-center">
    <h1 class="text-5xl md:text-6xl font-bold mb-6">Det Beste <span class="text-[var(--color-brand-red)]">IPTV Abonnement i Trondheim</span></h1>
    <p class="text-xl text-gray-300 mb-10">
      Krystallklar sport og film, direkte til din stue i Trondheim med IPTV Norway.
    </p>
  </div>

  <section class="py-12 px-4 max-w-4xl mx-auto prose prose-invert prose-red text-center">
    <p class="text-lg">
      Leter du etter det <strong>beste iptv</strong> tilbudet i <strong>Trondheim</strong>? Velg IPTV Norway for et kompromissløst <strong>iptv abonnement</strong>. Vi gir deg tilgang til det største innholdsbiblioteket med sylskarp 4K-oppløsning, spesialtilpasset for det norske markedet.
    </p>
  </section>

  <SetupSteps />
  <PricingCard />
</Layout>
