---
import Layout from '../../layouts/Layout.astro';
import PricingCard from '../../components/PricingCard.astro';
import SetupSteps from '../../components/SetupSteps.astro';
---

<Layout title="IPTV Abonnement Oslo - Beste IPTV i Oslo | IPTV Norway" description="Ser du etter det beste iptv abonnementet i Oslo? Få tilgang til tusenvis av kanaler, sport og filmer med IPTV Norway i Oslo. Prøv i dag!">
  <div class="pt-32 pb-10 px-4 max-w-4xl mx-auto text-center">
    <h1 class="text-5xl md:text-6xl font-bold mb-6">Det Beste <span class="text-[var(--color-brand-red)]">IPTV Abonnement i Oslo</span></h1>
    <p class="text-xl text-gray-300 mb-10">
      Opplev krystallklar 4K-kvalitet og stabil strømming i hovedstaden med IPTV Norway.
    </p>
  </div>

  <section class="py-12 px-4 max-w-4xl mx-auto prose prose-invert prose-red text-center">
    <p class="text-lg">
      Bor du i <strong>Oslo</strong> og ser etter Norges <strong>beste iptv</strong>? Våre lynraske servere sikrer at du kan nyte direktesendt sport, ferske filmer og internasjonale kanaler uten buffering. Med et <strong>iptv abonnement</strong> fra oss får du markedets beste verdi.
    </p>
  </section>

  <SetupSteps />
  <PricingCard />
</Layout>
