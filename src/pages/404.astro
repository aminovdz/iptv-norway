---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Siden ble ikke funnet | IPTV Norway" description="Beklager, siden du leter etter finnes ikke.">
  <div class="min-h-[70vh] flex flex-col items-center justify-center px-4 text-center">
    <h1 class="text-9xl font-bold text-[var(--color-brand-red)] mb-4">404</h1>
    <h2 class="text-3xl font-semibold mb-6">Siden ble ikke funnet</h2>
    <p class="text-gray-400 max-w-md mx-auto mb-8">
      Beklager, vi kunne ikke finne siden du lette etter. Kanskje du vil gå tilbake til forsiden for å utforske våre fantastiske IPTV-abonnementer?
    </p>
    <a href="/" class="px-8 py-3 bg-[var(--color-brand-blue)] hover:bg-blue-800 text-white rounded-full font-medium transition-colors">
      Gå til Forsiden
    </a>
  </div>
</Layout>
