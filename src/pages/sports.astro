---
import Layout from '../layouts/Layout.astro';
import LiveScores from '../components/widgets/LiveScores.astro';
---

<Layout title="Live Sport - IPTV Norway" description="Følg med på live sport og resultater med IPTV Norway. Norges beste utvalg av sport.">
  <div class="pt-32 pb-20 px-4 max-w-4xl mx-auto min-h-[70vh]">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Live <span class="text-[var(--color-brand-red)]">Sport</span></h1>
      <p class="text-xl text-gray-400">Hold deg oppdatert med de siste resultatene.</p>
    </div>
    
    <LiveScores />

    <div class="mt-16 rounded-3xl overflow-hidden border border-white/10 shadow-[0_0_50px_rgba(186,12,47,0.2)]">
      <img src="/images/sports.png" alt="iptv abonnement for live sport og filmer" class="w-full h-auto max-h-[500px] object-cover" />
    </div>
  </div>
</Layout>
