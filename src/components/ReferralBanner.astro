---
import { Gift, ArrowRight } from 'lucide-astro';
---

<section class="py-12 px-4 max-w-5xl mx-auto mb-20 mt-10">
  <div class="glass bg-gradient-to-r from-[var(--color-brand-blue)]/80 to-[var(--color-brand-red)]/80 p-8 md:p-12 rounded-3xl relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-8 border-[var(--color-brand-red)]/50 border-2 shadow-[0_0_30px_rgba(186,12,47,0.2)]">
    <!-- Decorative background element -->
    <div class="absolute -right-20 -top-20 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 flex flex-col md:flex-row items-center md:items-start text-center md:text-left gap-6">
      <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center shrink-0 shadow-lg backdrop-blur-sm mx-auto md:mx-0">
        <Gift class="w-8 h-8 text-white" />
      </div>
      <div>
        <h2 class="text-2xl md:text-4xl font-bold text-white mb-2">Verv en venn, få 1 måned gratis!</h2>
        <p class="text-gray-200 text-lg">Del gleden med krystallklar IPTV. Din venn får rabatt, og du får en gratis måned lagt til abonnementet ditt.</p>
      </div>
    </div>
    
    <a href="https://wa.me/18036582620?text=Hei,%20jeg%20vil%20gjerne%20verve%20en%20venn!" target="_blank" rel="noopener noreferrer" class="relative z-10 shrink-0 px-8 py-4 bg-white text-[var(--color-brand-blue)] hover:bg-gray-100 rounded-full font-bold text-lg transition-all transform hover:scale-105 shadow-xl flex items-center justify-center gap-2 w-full md:w-auto">
      Få Din Unike Lenke
      <ArrowRight class="w-5 h-5" />
    </a>
  </div>
</section>
