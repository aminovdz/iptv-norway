---
import { Check } from 'lucide-astro';

const plans = [
  {
    months: 1,
    title: "1 Måned",
    price: "80",
    features: ["Alle kanaler & VOD", "4K & HD Kvalitet", "Anti-Freeze teknologi", "Standard Support"],
    popular: false,
    link: "https://wa.me/18036582620?text=Hei,%20jeg%20vil%20kjøpe%201%20måned%20abonnement"
  },
  {
    months: 3,
    title: "3 Måneder",
    price: "200",
    features: ["Alle kanaler & VOD", "4K & HD Kvalitet", "Anti-Freeze teknologi", "Prioritert Support"],
    popular: false,
    link: "https://wa.me/18036582620?text=Hei,%20jeg%20vil%20kjøpe%203%20måneder%20abonnement"
  },
  {
    months: 6,
    title: "6 Måneder",
    price: "300",
    features: ["Alle kanaler & VOD", "4K & HD Kvalitet", "Anti-Freeze teknologi", "Prioritert Support"],
    popular: false,
    link: "https://wa.me/18036582620?text=Hei,%20jeg%20vil%20kjøpe%206%20måneder%20abonnement"
  },
  {
    months: 12,
    title: "12 Måneder",
    price: "550",
    features: ["Alle kanaler & VOD", "4K & HD Kvalitet", "Anti-Freeze teknologi", "24/7 Premium Support", "Gratis Premium App"],
    popular: true,
    link: "https://wa.me/18036582620?text=Hei,%20jeg%20vil%20kjøpe%2012%20måneder%20abonnement"
  }
];
---

<section id="priser" class="py-20 scroll-mt-24 border-t border-[var(--color-glass-border)]">
  <div class="text-center mb-16">
    <h2 class="text-3xl md:text-5xl font-bold mb-4">Velg Ditt <span class="text-[var(--color-brand-red)]">IPTV Abonnement</span></h2>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto">Ingen skjulte avgifter. Ingen bindingstid. Bare ren underholdning.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto">
    {plans.map((plan) => (
      <div class={`glass relative flex flex-col p-8 transition-transform duration-300 hover:-translate-y-2 ${plan.popular ? 'border-[var(--color-brand-red)] border-2 shadow-[0_0_30px_rgba(186,12,47,0.3)]' : ''}`}>
        {plan.popular && (
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[var(--color-brand-red)] text-white px-4 py-1 rounded-full text-sm font-bold tracking-wide uppercase">
            Beste Verdi
          </div>
        )}
        
        <div class="text-center mb-8 mt-4">
          <h3 class="text-xl text-gray-300 mb-2">{plan.title}</h3>
          <div class="flex items-end justify-center gap-1">
            <span class="text-5xl font-bold text-white">{plan.price}</span>
            <span class="text-gray-400 mb-1">NOK</span>
          </div>
          <p class="text-sm text-[var(--color-brand-red)] mt-2 font-medium">Bare {(parseInt(plan.price) / plan.months).toFixed(0)} NOK / måned</p>
        </div>
        
        <ul class="flex-1 flex flex-col gap-4 mb-8">
          {plan.features.map((feature) => (
            <li class="flex items-start gap-3">
              <Check class="w-5 h-5 text-green-400 shrink-0 mt-0.5" />
              <span class="text-gray-300">{feature}</span>
            </li>
          ))}
        </ul>
        
        <a href={plan.link} target="_blank" rel="noopener noreferrer" class={`block w-full py-4 rounded-xl text-center font-bold text-lg transition-colors ${plan.popular ? 'bg-[var(--color-brand-red)] hover:bg-red-700 text-white' : 'bg-white/10 hover:bg-white/20 text-white'}`}>
          Bestill Nå
        </a>
      </div>
    ))}
  </div>
</section>
