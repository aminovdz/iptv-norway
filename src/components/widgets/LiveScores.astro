---
// LiveScores.astro
---

<div id="live-scores-widget" class="glass p-6 max-w-4xl mx-auto hidden opacity-0 transition-opacity duration-500 my-8">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-xl font-bold flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></span>
      Live Sport (Premier League)
    </h3>
    <span class="text-xs font-bold bg-white/10 px-2 py-1 rounded text-gray-300" id="live-scores-status">Henter...</span>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="scores-container">
    <!-- Scores injected via JS -->
  </div>
</div>

<script>
  async function initLiveScores() {
    const widget = document.getElementById('live-scores-widget');
    const container = document.getElementById('scores-container');
    const status = document.getElementById('live-scores-status');
    if (!widget || !container) return;

    try {
      const response = await fetch('https://site.api.espn.com/apis/site/v2/sports/soccer/eng.1/scoreboard');
      const data = await response.json();
      
      if (!data.events || data.events.length === 0) {
        throw new Error("Ingen kamper");
      }

      // Display up to 4 matches
      const matches = data.events.slice(0, 4);
      
      container.innerHTML = matches.map(match => {
        const home = match.competitions[0].competitors.find((c: any) => c.homeAway === 'home');
        const away = match.competitions[0].competitors.find((c: any) => c.homeAway === 'away');
        const time = match.status.type.shortDetail; // e.g., "FT", "Halftime", "45'"
        
        return `
          <div class="flex items-center justify-between p-3 bg-black/30 rounded-lg border border-white/5">
            <div class="flex-1 font-medium text-right text-sm truncate pr-2">${home.team.shortDisplayName}</div>
            <div class="px-3 font-bold text-[var(--color-brand-red)] bg-white/5 rounded py-1">${home.score} - ${away.score}</div>
            <div class="flex-1 font-medium text-left text-sm truncate pl-2">${away.team.shortDisplayName}</div>
            <div class="text-xs text-gray-400 w-12 text-right">${time}</div>
          </div>
        `;
      }).join('');
      
      if (status) status.textContent = "OPPDATERT NÅ";
      
    } catch (e) {
      console.error("Error fetching ESPN scores:", e);
      container.innerHTML = '<div class="text-gray-400 text-sm">Ingen live kamper for øyeblikket.</div>';
      if (status) status.textContent = "FRAKOBLET";
    }

    widget.classList.remove('hidden');
    setTimeout(() => {
      widget.classList.remove('opacity-0');
    }, 50);
  }

  // Defer execution to protect INP
  if (typeof requestIdleCallback === 'function') {
    requestIdleCallback(initLiveScores);
  } else {
    setTimeout(initLiveScores, 500);
  }
</script>
