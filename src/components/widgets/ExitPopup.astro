---
import { X } from 'lucide-astro';
---
<div id="exit-popup-backdrop" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[100] hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4">
  <div id="exit-popup-modal" class="glass bg-gradient-to-br from-[var(--color-dark-bg)] to-[var(--color-brand-blue)]/50 p-8 md:p-12 max-w-lg w-full relative transform scale-95 transition-transform duration-300 border-[var(--color-brand-red)]/30 border text-center rounded-2xl">
    <button id="exit-popup-close" class="absolute top-4 right-4 text-gray-400 hover:text-white transition-colors" aria-label="Lukk">
      <X class="w-6 h-6" />
    </button>
    
    <h2 class="text-3xl md:text-4xl font-bold mb-4">Vent litt! 🎁</h2>
    <p class="text-lg text-gray-300 mb-8">Før du går, bruk rabattkoden <strong class="text-white bg-[var(--color-brand-red)] px-2 py-1 rounded">RABATT10</strong> for å få 10% avslag på ditt første kjøp!</p>
    
    <a href="https://wa.me/18036582620?text=Hei,%20jeg%20vil%20bruke%20rabattkoden%20RABATT10" target="_blank" rel="noopener noreferrer" class="block w-full py-4 bg-[var(--color-brand-red)] hover:bg-red-700 text-white font-bold rounded-xl text-lg transition-colors shadow-lg shadow-red-900/50">
      Bruk Rabattkode Nå
    </a>
    <button id="exit-popup-decline" class="mt-4 text-sm text-gray-500 hover:text-gray-300">Nei takk, jeg vil betale full pris</button>
  </div>
</div>

<script>
  function initExitPopup() {
    const backdrop = document.getElementById('exit-popup-backdrop');
    const modal = document.getElementById('exit-popup-modal');
    const closeBtn = document.getElementById('exit-popup-close');
    const declineBtn = document.getElementById('exit-popup-decline');
    
    if (!backdrop || !modal || !closeBtn || !declineBtn) return;
    
    let hasTriggered = false;

    function showPopup() {
      if (hasTriggered || sessionStorage.getItem('exit_popup_seen')) return;
      hasTriggered = true;
      sessionStorage.setItem('exit_popup_seen', 'true');
      
      backdrop.classList.remove('hidden');
      // small delay to allow display block to apply
      setTimeout(() => {
        backdrop.classList.remove('opacity-0');
        modal.classList.remove('scale-95');
      }, 10);
    }

    function hidePopup() {
      backdrop.classList.add('opacity-0');
      modal.classList.add('scale-95');
      setTimeout(() => {
        backdrop.classList.add('hidden');
      }, 300);
    }

    document.addEventListener('mouseleave', (e) => {
      if (e.clientY <= 0) {
        showPopup();
      }
    });

    closeBtn.addEventListener('click', hidePopup);
    declineBtn.addEventListener('click', hidePopup);
    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) hidePopup();
    });
  }

  if (typeof requestIdleCallback === 'function') {
    requestIdleCallback(initExitPopup);
  } else {
    setTimeout(initExitPopup, 1000);
  }
</script>
