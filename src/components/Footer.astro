---
---
<footer class="bg-[var(--color-dark-bg)] border-t border-[var(--color-glass-border)] py-12 px-4 mt-20 relative z-10">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
    
    <!-- Brand -->
    <div class="lg:col-span-3">
      <a href="/" class="text-2xl font-bold tracking-tighter flex items-center gap-2 mb-4">
        <span class="text-white">IPTV</span><span class="text-[var(--color-brand-red)]">Norway</span>
      </a>
      <p class="text-sm text-gray-400">
        Norges ledende leverandør av førsteklasses IPTV abonnement. Vi leverer stabilt og høykvalitets innhold til tusenvis av fornøyde kunder.
      </p>
    </div>

    <!-- Hjelp og Guider -->
    <div class="lg:col-span-2 lg:col-start-5">
      <h3 class="font-bold text-white mb-4">Hjelp & Ressurser</h3>
      <ul class="space-y-2 text-sm text-gray-400">
        <li><a href="/guides/oppsett-av-iptv" class="hover:text-[var(--color-brand-red)] transition-colors">Slik setter du opp IPTV</a></li>
        <li><a href="/compare/iptv-vs-parabol" class="hover:text-[var(--color-brand-red)] transition-colors">IPTV vs Parabol</a></li>
        <li><a href="/sports" class="hover:text-[var(--color-brand-red)] transition-colors">Live Sport</a></li>
        <li><a href="/#priser" class="hover:text-[var(--color-brand-red)] transition-colors">Se Våre Priser</a></li>
      </ul>
    </div>

    <!-- Lokale Sider & Juridisk -->
    <div class="lg:col-span-2">
      <h3 class="font-bold text-white mb-4">Finn oss lokalt</h3>
      <ul class="space-y-2 text-sm text-gray-400 mb-6">
        <li><a href="/locations/oslo" class="hover:text-[var(--color-brand-red)] transition-colors">IPTV Abonnement Oslo</a></li>
        <li><a href="/locations/bergen" class="hover:text-[var(--color-brand-red)] transition-colors">IPTV Abonnement Bergen</a></li>
        <li><a href="/locations/trondheim" class="hover:text-[var(--color-brand-red)] transition-colors">IPTV Abonnement Trondheim</a></li>
      </ul>
      <h3 class="font-bold text-white mb-3">Juridisk</h3>
      <ul class="space-y-2 text-sm text-gray-400">
        <li><a href="/terms" class="hover:text-[var(--color-brand-red)] transition-colors">Brukervilkår</a></li>
        <li><a href="/privacy" class="hover:text-[var(--color-brand-red)] transition-colors">Personvern</a></li>
        <li><a href="/refund" class="hover:text-[var(--color-brand-red)] transition-colors">Refusjonspolicy</a></li>
        <li><a href="/dmca" class="hover:text-[var(--color-brand-red)] transition-colors">DMCA / Opphavsrett</a></li>
      </ul>
    </div>

    <!-- Map -->
    <div class="lg:col-span-3 lg:col-start-10">
      <h3 class="font-bold text-white mb-4">Vårt Område</h3>
      <div class="rounded-xl overflow-hidden border border-[var(--color-glass-border)] shadow-lg h-40 relative bg-gray-900">
        <!-- Using filter to make Google Maps match dark mode aesthetic -->
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d8088916.31175655!2d0.6200234032130325!3d64.57315354979178!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x461268458f4de5bf%3A0xa1b03b9db864d02b!2sNorway!5e0!3m2!1sen!2sus!4v1683935293630!5m2!1sen!2sus" 
          class="absolute inset-0 w-full h-full" 
          style="border:0; filter: invert(90%) hue-rotate(180deg) contrast(1.1);" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto mt-12 pt-8 border-t border-[var(--color-glass-border)] text-center text-sm text-gray-500">
    &copy; {new Date().getFullYear()} IPTV Norway. Alle rettigheter reservert. Dette nettstedet hoster ikke opphavsrettsbeskyttet materiale.
  </div>
</footer>
